{
  "name": "hash-forge-mcp",
  "description": "MCP server for cryptographic hashing \u2014 MD5, SHA-1, SHA-256, SHA-384, SHA-512",
  "version": "1.0.1",
  "vendor": "Sovereign (Taylor)",
  "sourceUrl": "https://github.com/ryudi84/sovereign-mcp-servers/tree/main/hash-forge",
  "homepage": "https://github.com/ryudi84/sovereign-mcp-servers",
  "license": "MIT",
  "runtime": "node",
  "command": {
    "npx": {
      "command": "npx",
      "args": [
        "-y",
        "hash-forge-mcp"
      ]
    }
  },
  "tools": [
    {
      "name": "hash_text",
      "description": "Hash text with all algorithms: MD5, SHA-1, SHA-256, SHA-384, SHA-512."
    },
    {
      "name": "compute_hmac",
      "description": "Generate an HMAC signature."
    },
    {
      "name": "compare_hashes",
      "description": "Compare two hash strings (case-insensitive)."
    }
  ],
